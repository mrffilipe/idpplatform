# Copy to docker/.env and adjust before starting the application stack.
# Used by: docker compose -f docker/docker-compose.yml --env-file docker/.env up -d
#
# Requires PostgreSQL and Redis reachable from the API container (see connection strings below).

# --- Published images (Docker Hub) ---
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

API_HOST_PORT=5000
FRONTEND_HOST_PORT=3000

# --- Database (required) ---
# With docker-compose.infrastructure.yml on network idpplatform-infra:
Database__ConnectionString=Host=postgres;Port=5432;Database=idpplatform_db;Username=postgres;Password=postgrespassword
# With PostgreSQL on the host (Windows / macOS):
# Database__ConnectionString=Host=host.docker.internal;Port=5432;Database=idpplatform_db;Username=postgres;Password=postgrespassword

Database__ApplyMigrationsOnStartup=true

# --- JWT / OIDC (required) ---
# Public URL of the API as seen by browsers (must match the host:port mapped above).
Jwt__Issuer=http://localhost:5000
Jwt__Audience=idpplatform-api
Jwt__KeyId=default
Jwt__RefreshTokenDays=30

# Option A: inline PEM (escape newlines or use docker secrets in production)
# Jwt__SigningKeyPem=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Option B: mount a key file (uncomment volume in docker-compose.yml and set path)
Jwt__SigningKeyPath=keys/oidc-signing.pem

# --- Redis (recommended in production) ---
Redis__ConnectionString=redis:6379,password=default_password,ssl=false
Redis__InstanceName=idpplatform:
Redis__TenantIdentifierCacheMinutes=5
# Leave Redis__ConnectionString empty to use in-memory cache (not recommended for production).

# --- Data Protection key ring (persistent volume is mounted at /app/keys/data-protection) ---
SecretProtection__KeyDirectoryPath=keys/data-protection
SecretProtection__ApplicationName=IdPPlatform

# --- Bootstrap (first deploy only — remove after successful bootstrap) ---
Bootstrap__AdminEmail=admin@example.com
Bootstrap__AdminPassword=ChangeMe_Strong_Password_12
Bootstrap__AdminDisplayName=Platform Admin

# --- Email (AWS SES — required for invite emails) ---
Email__FromAddress=noreply@example.com
Email__Region=us-east-1
Email__AccessKeyId=
Email__SecretAccessKey=
Email__SessionToken=

# --- Rate limits / invites / password policy (optional overrides) ---
# RateLimit__BootstrapPermitLimit=3
# Invite__ExpirationHours=72
# PasswordPolicy__MinLength=12
