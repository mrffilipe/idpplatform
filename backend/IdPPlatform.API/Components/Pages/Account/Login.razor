@page "/account/login"
@using IdPPlatform.API.Common
@using IdPPlatform.Application.Services.IdentityProvider
@using IdPPlatform.Domain.Enums
@using IdPPlatform.Domain.Repositories
@using Microsoft.AspNetCore.Antiforgery
@inject IIdentityProviderRepository IdentityProviders
@inject IIdentityProviderConfigCipher ConfigCipher
@inject IAntiforgery Antiforgery
@inject HttpContext HttpContext

<HeadContent>
    <title>Sign in - IdP Platform</title>
</HeadContent>

<div class="account-page">
    <header class="account-header">
        <h1>Welcome back</h1>
        <p class="account-subtitle">Sign in to continue to your applications.</p>
    </header>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="account-alert" role="alert" aria-live="polite">
            @ResolveErrorMessage(Error)
        </div>
    }

    @if (_showLocal)
    {
        <form method="post" action="/account/login" class="account-form" novalidate>
            <input type="hidden" name="__RequestVerificationToken" value="@_antiforgeryToken" />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div class="account-field">
                <label for="email">Email</label>
                <input id="email"
                       type="email"
                       name="email"
                       autocomplete="username"
                       inputmode="email"
                       required
                       placeholder="you@company.com" />
            </div>

            <div class="account-field">
                <label for="password">Password</label>
                <input id="password"
                       type="password"
                       name="password"
                       autocomplete="current-password"
                       required
                       placeholder="••••••••" />
            </div>

            <button type="submit" class="account-btn account-btn-primary">
                Sign in
            </button>
        </form>
    }
    else
    {
        <div class="account-notice" role="status">
            Local email + password is not enabled. Use a federated provider below or contact your administrator.
        </div>
    }

    @if (_showLocal && _federated.Count > 0)
    {
        <div class="account-divider"><span>or continue with</span></div>
    }

    @if (_federated.Count > 0)
    {
        <form id="external-login-form" method="post" action="/account/external-login" class="account-hidden-form">
            <input type="hidden" name="__RequestVerificationToken" value="@_antiforgeryToken" />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <input type="hidden" name="providerAlias" id="external-provider-alias" />
            <input type="hidden" name="idToken" id="external-id-token" />
        </form>

        <div class="account-social">
            @foreach (var provider in _federated)
            {
                if (provider.ProviderType == nameof(IdentityProviderType.Firebase) && provider.ClientConfig is not null)
                {
                    <button type="button"
                            class="account-btn account-btn-social account-btn-google firebase-login-btn"
                            data-alias="@provider.Alias"
                            data-api-key="@provider.ClientConfig["webApiKey"]"
                            data-project-id="@provider.ClientConfig["projectId"]"
                            data-auth-domain="@provider.ClientConfig["authDomain"]">
                        <span class="account-social-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                                <path d="M21.35 11.1H12v2.84h5.36c-.23 1.5-1.7 4.41-5.36 4.41-3.23 0-5.87-2.68-5.87-5.98 0-3.3 2.64-5.98 5.87-5.98 1.84 0 3.07.78 3.78 1.46l2.58-2.49C16.93 3.94 14.7 3 12 3 6.99 3 2.95 7.04 2.95 12c0 4.96 4.04 9 9.05 9 5.23 0 8.7-3.68 8.7-8.86 0-.59-.07-1.05-.16-1.49z" fill="currentColor"/>
                            </svg>
                        </span>
                        Continue with Google — @provider.DisplayName
                    </button>
                }
                else
                {
                    <div class="account-hint">
                        @provider.DisplayName: sign-in is not yet implemented for this provider type.
                    </div>
                }
            }
        </div>
    }

    <footer class="account-footer">
        <span>Don't have an account?</span>
        <a href="@($"/account/register?returnUrl={Uri.EscapeDataString(ReturnUrl ?? string.Empty)}")">Create one</a>
    </footer>
</div>

@if (_hasFirebase)
{
    <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
    <script>
        (function () {
            const form = document.getElementById('external-login-form');
            const aliasInput = document.getElementById('external-provider-alias');
            const tokenInput = document.getElementById('external-id-token');

            // Initialize Firebase app instances per alias so we can navigate to Google in the same tab.
            function ensureApp(alias, apiKey, projectId, authDomain) {
                const appName = 'idp-' + alias;
                try {
                    return firebase.app(appName);
                } catch (_) {
                    return firebase.initializeApp({ apiKey, projectId, authDomain }, appName);
                }
            }

            // After Google returns we land back on this page with a redirect result. Pick it up and submit.
            document.querySelectorAll('.firebase-login-btn').forEach(function (btn) {
                const alias = btn.getAttribute('data-alias');
                const apiKey = btn.getAttribute('data-api-key');
                const projectId = btn.getAttribute('data-project-id');
                const authDomain = btn.getAttribute('data-auth-domain');

                ensureApp(alias, apiKey, projectId, authDomain);

                btn.addEventListener('click', async function () {
                    btn.disabled = true;
                    try {
                        const app = ensureApp(alias, apiKey, projectId, authDomain);
                        const auth = firebase.auth(app);
                        const provider = new firebase.auth.GoogleAuthProvider();
                        // Full-page redirect to accounts.google.com — same window, no popup.
                        await auth.signInWithRedirect(provider);
                    } catch (err) {
                        console.error(err);
                        alert('Could not start Google sign-in. Ensure Google is enabled in Firebase Console and authDomain matches.');
                        btn.disabled = false;
                    }
                });
            });

            // Collect the redirect result from any Firebase app initialised on this page.
            async function processRedirectResults() {
                const btn = document.querySelector('.firebase-login-btn');
                if (!btn) return;
                const alias = btn.getAttribute('data-alias');
                const apiKey = btn.getAttribute('data-api-key');
                const projectId = btn.getAttribute('data-project-id');
                const authDomain = btn.getAttribute('data-auth-domain');
                const app = ensureApp(alias, apiKey, projectId, authDomain);
                const auth = firebase.auth(app);
                try {
                    const result = await auth.getRedirectResult();
                    if (result && result.user) {
                        const idToken = await result.user.getIdToken();
                        aliasInput.value = alias;
                        tokenInput.value = idToken;
                        form.submit();
                    }
                } catch (err) {
                    console.error('Google redirect result error', err);
                }
            }

            processRedirectResults();
        })();
    </script>
}

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private bool _showLocal;
    private bool _hasFirebase;
    private IReadOnlyList<FederatedProviderViewData> _federated = Array.Empty<FederatedProviderViewData>();
    private string _antiforgeryToken = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _antiforgeryToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken ?? string.Empty;

        var enabled = await IdentityProviders.ListEnabledAsync(HttpContext.RequestAborted);
        _showLocal = enabled.Any(p => p.ProviderType == IdentityProviderType.Local && p.Capabilities.Contains(IdpCapability.LocalPassword));

        _federated = enabled
            .Where(p => p.ProviderType != IdentityProviderType.Local)
            .Select(p => new FederatedProviderViewData
            {
                Alias = p.Alias,
                DisplayName = p.DisplayName,
                ProviderType = p.ProviderType.ToString(),
                ClientConfig = FederatedProviderClientConfig.Build(p.ProviderType, ConfigCipher.Decrypt(p.ConfigJson))
            })
            .ToList();

        _hasFirebase = _federated.Any(p => p.ProviderType == nameof(IdentityProviderType.Firebase) && p.ClientConfig is not null);
    }

    private static string ResolveErrorMessage(string code) => code switch
    {
        "invalid_credentials" => ApiErrorMessages.Account.InvalidEmailOrPassword,
        "missing_fields" => ApiErrorMessages.Account.EmailAndPasswordRequired,
        "invalid_provider" => ApiErrorMessages.Account.InvalidProviderOrToken,
        _ => "Sign-in failed. Please try again."
    };

    private sealed class FederatedProviderViewData
    {
        public required string Alias { get; init; }

        public required string DisplayName { get; init; }

        public required string ProviderType { get; init; }

        public IReadOnlyDictionary<string, string>? ClientConfig { get; init; }
    }
}
