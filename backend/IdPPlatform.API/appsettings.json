{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Database": {
    "ConnectionString": "Definir connection string do PostgreSQL no appsettings de ambiente (ex: appsettings.Development.json)"
  },

  "Jwt": {
    "Issuer": "https://your-idp-host",
    "Audience": "idpplatform-api",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30,
    "SigningKeyPath": "keys/oidc-signing.pem",
    "SigningKeyPem": "",
    "KeyId": "default"
  },

  "Bootstrap": {
    "AdminEmail": "Definir via env var PLATFORM_BOOTSTRAP_ADMIN_EMAIL (ou aqui apenas em desenvolvimento local)",
    "AdminPassword": "Definir via env var PLATFORM_BOOTSTRAP_ADMIN_PASSWORD — nunca commitar senha real",
    "AdminDisplayName": "Definir via env var PLATFORM_BOOTSTRAP_ADMIN_DISPLAY_NAME (opcional)"
  },

  "Session": {
    "MaxSessionsPerUser": 5
  },

  "RateLimit": {
    "BootstrapPermitLimit": 3,
    "BootstrapWindowMinutes": 15
  },

  "Invite": {
    "ExpirationHours": 72
  },

  "Email": {
    "FromAddress": "noreply@example.com",
    "Region": "us-east-1",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "SessionToken": ""
  },

  "Redis": {
    "ConnectionString": "",
    "InstanceName": "idpplatform:",
    "TenantIdentifierCacheMinutes": 5
  }
}
