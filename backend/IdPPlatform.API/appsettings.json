{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Database": {
    "ConnectionString": ""
  },

  "Jwt": {
    "Issuer": "http://localhost:5000",
    "Audience": "idpplatform-api",
    "RefreshTokenDays": 30,
    "SigningKeyPath": "keys/oidc-signing.pem",
    "SigningKeyPem": "",
    "KeyId": "default"
  },

  "Bootstrap": {
    "AdminEmail": "",
    "AdminPassword": "",
    "AdminDisplayName": ""
  },

  "RateLimit": {
    "BootstrapPermitLimit": 3,
    "BootstrapWindowMinutes": 15,
    "AccountRegisterPermitLimit": 5,
    "AccountRegisterWindowMinutes": 15
  },

  "Invite": {
    "ExpirationHours": 72
  },

  "Email": {
    "FromAddress": "noreply@example.com",
    "Region": "us-east-1",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "SessionToken": ""
  },

  "Redis": {
    "ConnectionString": "",
    "InstanceName": "idpplatform:",
    "TenantIdentifierCacheMinutes": 5
  },

  "SecretProtection": {
    "KeyDirectoryPath": "keys/data-protection",
    "ApplicationName": "IdPPlatform"
  },

  "PasswordPolicy": {
    "MinLength": 12,
    "RequireDigit": true,
    "RequireLetter": true
  }
}
