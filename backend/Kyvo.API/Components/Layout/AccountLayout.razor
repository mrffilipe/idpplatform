@inherits LayoutComponentBase

<AccountThemeToggle />

<div class="account-shell">
    <aside class="account-hero" aria-hidden="true">
        <div class="account-hero-content">
            <AccountBrandLogo CssClass="account-hero-brand" />
            <h2 class="account-hero-title">Identity for an ecosystem of apps.</h2>
            <p class="account-hero-subtitle">
                One central place for users, tenants and OAuth applications.
                Sign in once, access every product.
            </p>
        </div>
    </aside>
    <main class="account-panel">
        <div class="account-card">
            @Body
        </div>
    </main>
</div>
